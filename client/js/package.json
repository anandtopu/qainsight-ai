{
  "name": "qainsight-reporter",
  "version": "1.0.0",
  "description": "QA Insight AI — JavaScript/TypeScript client SDK for live test execution streaming",
  "main": "dist/qainsight-reporter.js",
  "types": "dist/qainsight-reporter.d.ts",
  "exports": {
    ".":                  { "import": "./dist/qainsight-reporter.js", "types": "./dist/qainsight-reporter.d.ts" },
    "./jest-reporter":    { "import": "./dist/jest-reporter.js",      "types": "./dist/jest-reporter.d.ts" },
    "./mocha-reporter":   { "import": "./dist/mocha-reporter.js",     "types": "./dist/mocha-reporter.d.ts" }
  },
  "scripts": {
    "build":    "tsc",
    "build:watch": "tsc --watch",
    "lint":     "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "files": ["dist", "src"],
  "keywords": ["qainsight", "test-reporting", "live-streaming", "jest", "mocha"],
  "license": "MIT",
  "engines": { "node": ">=18.0.0" },
  "devDependencies": {
    "@types/node":        "^20.0.0",
    "@types/mocha":       "^10.0.0",
    "typescript":         "^5.3.0"
  },
  "peerDependencies": {
    "jest":   ">=27.0.0",
    "mocha":  ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "jest":  { "optional": true },
    "mocha": { "optional": true }
  }
}
