{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "QA Insight AI — Application Overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "HTTP Traffic",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"qainsight-backend\"}[5m])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"qainsight-backend\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"qainsight-backend\"}[5m]))",
          "legendFormat": "5xx Rate",
          "refId": "A"
        }
      ],
      "title": "HTTP 5xx Error Rate",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"qainsight-backend\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"qainsight-backend\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"qainsight-backend\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "HTTP Latency Percentiles",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 10,
      "title": "AI Pipeline",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 11,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "sum(increase(qainsight_ai_analyses_total[5m])) by (workflow_type, status)",
          "legendFormat": "{{workflow_type}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "AI Pipeline Completions (5m)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(qainsight_pipeline_stage_duration_seconds_bucket[5m])) by (stage_name, le))",
          "legendFormat": "{{stage_name}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(qainsight_pipeline_stage_duration_seconds_bucket[5m])) by (stage_name, le))",
          "legendFormat": "{{stage_name}} p95",
          "refId": "B"
        }
      ],
      "title": "Agent Stage Duration by Stage",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(qainsight_active_pipeline_runs) by (workflow_type)",
          "legendFormat": "{{workflow_type}}",
          "refId": "A"
        }
      ],
      "title": "Active Pipeline Runs",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 20,
      "title": "LLM & Release Gate",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 21,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(qainsight_llm_request_duration_seconds_bucket[5m])) by (provider, le))",
          "legendFormat": "{{provider}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(qainsight_llm_request_duration_seconds_bucket[5m])) by (provider, le))",
          "legendFormat": "{{provider}} p95",
          "refId": "B"
        }
      ],
      "title": "LLM Inference Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 22,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "sum(increase(qainsight_release_decisions_total[1h])) by (recommendation)",
          "legendFormat": "{{recommendation}}",
          "refId": "A"
        }
      ],
      "title": "Release Decisions (1h)",
      "type": "barchart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 30,
      "title": "Celery & Ingestion",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 31,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "sum(increase(qainsight_celery_tasks_total[5m])) by (task_name, status)",
          "legendFormat": "{{task_name}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Celery Tasks (5m)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 32,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "list" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "sum(increase(qainsight_ingestion_test_cases_total[5m])) by (framework, status)",
          "legendFormat": "{{framework}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Test Cases Ingested (5m)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["qainsight", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "QA Insight AI — Overview",
  "uid": "qainsight-overview-v1",
  "version": 1
}
