# QA Insight AI MCP Server — Cloud Run environment variables
# Copy to infra/cloudrun/mcp.env and replace placeholders.
# Upload with:
#   gcloud secrets versions add qainsight-mcp-env --data-file=infra/cloudrun/mcp.env

# Backend URL — use the Cloud Run backend service URL
QAINSIGHT_API_URL=https://qainsight-backend-xxxx-uc.a.run.app

# MCP service account credentials (must match a registered user in the backend)
# Create via: POST /api/v1/auth/register
QAINSIGHT_USERNAME=mcp-service-account
QAINSIGHT_PASSWORD=CHANGE_ME_STRONG

# HTTP timeout in seconds (increase for slow LLMs; AI analysis can take 60+s)
QAINSIGHT_REQUEST_TIMEOUT=120.0
