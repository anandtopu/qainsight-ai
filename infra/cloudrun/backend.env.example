# Copy to infra/cloudrun/backend.env and replace placeholders.

APP_NAME=QA Insight AI
APP_ENV=production
APP_DEBUG=false
APP_VERSION=0.0.1
APP_SECRET_KEY=replace-with-strong-random
CORS_ORIGINS=https://YOUR_FRONTEND_RUN_URL

# Cloud SQL Unix socket format
# /cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql+asyncpg://qainsight_user:CHANGE_ME@/qainsight?host=/cloudsql/PROJECT:REGION:INSTANCE
POSTGRES_DB=qainsight
POSTGRES_USER=qainsight_user
POSTGRES_PASSWORD=CHANGE_ME

MONGO_DB=qainsight_logs
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?retryWrites=true&w=majority

REDIS_URL=redis://USER:PASSWORD@HOST:PORT/0
CELERY_BROKER_URL=redis://USER:PASSWORD@HOST:PORT/0
CELERY_RESULT_BACKEND=redis://USER:PASSWORD@HOST:PORT/1
CELERY_WORKER_CONCURRENCY=1

# S3-compatible object storage endpoint
MINIO_ENDPOINT=s3.amazonaws.com
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET_NAME=test-telemetry
MINIO_USE_SSL=true

LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash
GOOGLE_API_KEY=CHANGE_ME
AI_OFFLINE_MODE=false

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=CHANGE_ME
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=qainsight_embeddings

JIRA_ENABLED=false
SPLUNK_ENABLED=false
OCP_ENABLED=false
SLACK_ENABLED=false

JWT_SECRET_KEY=replace-with-strong-random
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

LOG_LEVEL=INFO
LOG_FORMAT=json

