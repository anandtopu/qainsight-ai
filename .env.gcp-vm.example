# ============================================================
# QA Insight AI — GCP VM environment template
# Copy to .env on VM and set real secrets before deployment
# ============================================================

APP_NAME=QA Insight AI
APP_ENV=production
APP_DEBUG=false
APP_VERSION=3.0.0
APP_SECRET_KEY=replace-with-strong-random-value
CORS_ORIGINS=http://localhost,http://YOUR_VM_PUBLIC_IP

POSTGRES_DB=qainsight
POSTGRES_USER=qainsight_user
POSTGRES_PASSWORD=replace-with-strong-db-password

MONGO_DB=qainsight_logs

MINIO_ACCESS_KEY=replace-with-minio-user
MINIO_SECRET_KEY=replace-with-minio-password
MINIO_BUCKET_NAME=test-telemetry
MINIO_USE_SSL=false

# Frontend build-time API URL. Set to your public backend endpoint.
VITE_API_BASE_URL=http://YOUR_VM_PUBLIC_IP:8000

LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash
GOOGLE_API_KEY=replace-with-gemini-api-key
AI_OFFLINE_MODE=false

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

JIRA_ENABLED=false
SPLUNK_ENABLED=false
OCP_ENABLED=false
SLACK_ENABLED=false

JWT_SECRET_KEY=replace-with-strong-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

CELERY_WORKER_CONCURRENCY=1

LOG_LEVEL=INFO
LOG_FORMAT=json

