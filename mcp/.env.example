# QA Insight AI MCP Server — Environment Variables
# Copy to .env and fill in values before running.
#
# For Claude Desktop (stdio mode): set these in the mcpServers.env block
# in ~/.claude/claude_desktop_config.json instead.

# Backend URL (default: local dev stack)
QAINSIGHT_API_URL=http://localhost:8000

# Credentials (optional — if not set, unauthenticated requests are attempted)
# Create a user first: POST /api/v1/auth/register
QAINSIGHT_USERNAME=your-username
QAINSIGHT_PASSWORD=your-password

# HTTP timeout in seconds (increase for slow LLMs; AI analysis can take 60+s)
QAINSIGHT_REQUEST_TIMEOUT=120.0
