# ============================================================
# QA Insight AI — Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_NAME=QA Insight AI
APP_ENV=development          # development | staging | production
APP_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
APP_DEBUG=true
APP_VERSION=3.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=qainsight
POSTGRES_USER=qainsight_user
POSTGRES_PASSWORD=changeme_local_dev
DATABASE_URL=postgresql+asyncpg://qainsight_user:changeme_local_dev@localhost:5432/qainsight

# ── MongoDB ──────────────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=qainsight_logs
MONGO_USER=
MONGO_PASSWORD=
MONGO_URI=mongodb://localhost:27017

# ── MinIO (S3-compatible Object Storage) ─────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET_NAME=test-telemetry
MINIO_USE_SSL=false

# ── Redis (Celery message broker) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ── LLM Provider Configuration ───────────────────────────────
# Provider: ollama (default/offline) | lmstudio | localai | vllm | openai | gemini
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Ollama (local — no internet required)
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio (local desktop app)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# LocalAI (air-gapped server)
# LOCALAI_BASE_URL=http://localhost:8080/v1

# vLLM (GPU production server)
# VLLM_BASE_URL=http://localhost:8000/v1

# OpenAI (cloud — requires internet)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-your-key-here

# Google Gemini (cloud — requires internet)
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-pro
# GOOGLE_API_KEY=your-google-api-key

# ── Embedding Configuration ───────────────────────────────────
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# ── ChromaDB (Vector Store for Semantic Search) ───────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=qainsight_embeddings

# ── AI Agent Settings ─────────────────────────────────────────
AI_OFFLINE_MODE=true          # true = enforce local-only; false = allow cloud APIs
AI_CONFIDENCE_THRESHOLD=80    # Minimum confidence for auto-Jira ticket creation
AI_MAX_RETRIES=3
AI_TIMEOUT_SECONDS=120

# ── Jira Integration (Optional — Phase 5) ────────────────────
JIRA_ENABLED=false
JIRA_DOMAIN=yourcompany.atlassian.net
JIRA_EMAIL=admin@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_DEFAULT_PROJECT_KEY=QA

# ── Splunk Integration (Optional — Phase 5) ──────────────────
SPLUNK_ENABLED=false
SPLUNK_BASE_URL=https://your-splunk-instance:8089
SPLUNK_API_TOKEN=your-splunk-token
SPLUNK_INDEX=main

# ── OpenShift / Kubernetes Integration ───────────────────────
OCP_ENABLED=false
OCP_API_URL=https://api.your-cluster.com:6443
OCP_SA_TOKEN=your-service-account-token
OCP_DEFAULT_NAMESPACE=qa-testing

# ── Notification Integrations (Optional — Phase 6) ───────────
SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_DEFAULT_CHANNEL=#qa-alerts

TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=https://yourorg.webhook.office.com/webhookb2/...

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@qainsight.io

# ── Authentication & Security ─────────────────────────────────
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Celery Worker ─────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=4

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json               # json | text
